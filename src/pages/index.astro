---
import DocLayout from "@layouts/DocLayout.astro";
import { getCollection } from "astro:content";

const episodes = await getCollection("episodes");
const sorted = episodes.sort((a, b) => b.data.episode - a.data.episode);
const latest = sorted.slice(0, 6);
const firstEp = latest[0];
---

<DocLayout title="Critical Thinking Bug Bounty Podcast — Summaries">
  <div class="page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-body">
        <div class="hero-badges">
          <span class="badge badge--accent">179 Episodes</span>
          <span class="badge">Bug Bounty</span>
          <span class="badge">AI-Summarized</span>
        </div>
        <h1 class="hero-title">
          Critical Thinking<br />
          <span class="hero-accent">Bug Bounty Podcast</span>
        </h1>
        <p class="hero-desc">
          Every episode distilled into structured analyst notes&mdash;bugs,
          techniques, tooling, and actionable takeaways. Powered by AI,
          curated for serious hunters.
        </p>
        <div class="hero-actions">
          <a href="/search" class="btn btn--primary">
            <svg width="15" height="15" viewBox="0 0 18 18" fill="none">
              <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 12l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Search Episodes
          </a>
          <a href="/quotes" class="btn btn--secondary">
            <svg width="15" height="15" viewBox="0 0 18 18" fill="none">
              <path d="M3 3h4v4H3V3zm8 0h4v4h-4V3zM3 11h4v4H3v-4zm8 0h4v4h-4v-4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Good Quotes
          </a>
          <a href="https://criticalthinkingpodcast.io" target="_blank" rel="noopener" class="btn btn--ghost">
            <svg width="15" height="15" viewBox="0 0 18 18" fill="none">
              <path d="M6 4l6 5-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Podcast
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-terminal">
          <div class="terminal-header">
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
          </div>
          <div class="terminal-body">
            <div class="terminal-line"><span class="term-label">$</span> <span class="term-cmd">recon --depth full</span></div>
            <div class="terminal-line"><span class="term-label">$</span> <span class="term-cmd">analyze --target api</span></div>
            <div class="terminal-line"><span class="term-muted">found 3 endpoints</span></div>
            <div class="terminal-line"><span class="term-label">$</span> <span class="term-cmd">exploit --vector xss</span></div>
            <div class="terminal-line"><span class="term-accent">$ dig deeper</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats">
      <div class="stat">
        <span class="stat-num">179</span>
        <span class="stat-label">Episodes</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">205</span>
        <span class="stat-label">Bug Types</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">481</span>
        <span class="stat-label">Techniques</span>
      </div>
    </section>

    <!-- Explore -->
    <section class="section">
      <h2 class="section-title">Explore</h2>
      <div class="grid-2x2">
        <a href={`/episodes/${firstEp.data.episode}`} class="card">
          <div class="card-icon">
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="M3 3h5v5H3V3zm7 0h5v5h-5V3zM3 10h5v5H3v-5zm7 0h5v5h-5v-5z" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="card-body">
            <div class="card-title">Latest Episode</div>
            <div class="card-desc">Episode {firstEp.data.episode} &mdash; {firstEp.data.title}</div>
          </div>
        </a>
        <a href="/search" class="card">
          <div class="card-icon">
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
              <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 12l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="card-body">
            <div class="card-title">Full-Text Search</div>
            <div class="card-desc">Search across all episodes by keyword, bug type, technique</div>
          </div>
        </a>
      </div>
    </section>

    <!-- Recent Episodes -->
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Recent Episodes</h2>
        <a href="/search" class="section-link">View all</a>
      </div>
      <div class="episodes-list">
        {latest.map((ep) => (
          <a href={`/episodes/${ep.data.episode}`} class="ep-row">
            <span class="ep-num">#{String(ep.data.episode).padStart(3, "0")}</span>
            <span class="ep-title">{ep.data.title}</span>
            <svg class="ep-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </section>


    <!-- About -->
    <section class="section about">
      <h2 class="section-title">About</h2>
      <div class="about-content">
        <p class="about-text">
          The <strong>Critical Thinking Bug Bounty Podcast</strong> features security researchers
          discussing real-world vulnerabilities, creative attack chains, and the methodologies
          behind successful bug bounty hunting. This site provides structured, AI-generated
          summaries of every episode&mdash;making the knowledge searchable, cross-referenced,
          and easier to digest.
        </p>
        <p class="about-text">
          Each summary captures bugs, techniques, and actionable advice.
          Use the search or browse episodes to find what interests you.
        </p>
      </div>
      <div class="about-credit">
        Built by <a href="https://x.com/NineRemmy" target="_blank" rel="noopener">Remmy9</a>
      </div>
    </section>
  </div>
</DocLayout>

<style>
  .page {
    max-width: 100%;
  }

  /* === Hero === */
  .hero {
    display: flex;
    gap: 48px;
    padding: 48px 0 40px;
    align-items: flex-start;
  }

  .hero-body {
    flex: 1;
    min-width: 0;
  }

  .hero-visual {
    flex-shrink: 0;
    width: 240px;
    padding-top: 8px;
  }

  .hero-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .badge {
    font-size: 12px;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-tertiary);
    display: inline-block;
  }

  .badge--accent {
    background: var(--accent-bg);
    border-color: transparent;
    color: var(--accent);
  }

  .hero-title {
    font-size: 36px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 0;
  }

  .hero-accent {
    color: var(--accent);
  }

  .hero-desc {
    margin-top: 16px;
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 500px;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  /* Terminal graphic */
  .hero-terminal {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .terminal-header {
    display: flex;
    gap: 6px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-elevated);
  }

  .terminal-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--border);
  }

  .terminal-body {
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.9;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .terminal-line {
    display: flex;
    gap: 6px;
  }

  .term-label { color: var(--text-tertiary); }
  .term-cmd { color: var(--text); }
  .term-muted { color: var(--text-tertiary); }
  .term-accent { color: var(--accent); font-weight: 500; }

  /* === Buttons === */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn--primary {
    background: var(--accent);
    color: var(--text-on-accent);
    border-color: transparent;
  }

  .btn--primary:hover {
    background: var(--accent-hover);
    color: var(--text-on-accent);
    box-shadow: 0 2px 8px rgba(124, 58, 237, 0.25);
  }

  .btn--primary:active {
    transform: scale(0.98);
  }

  .btn--secondary {
    background: var(--bg-card);
    color: var(--text);
    border-color: var(--border);
  }

  .btn--secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: var(--shadow-card);
  }

  .btn--ghost {
    background: transparent;
    color: var(--text-tertiary);
    border-color: transparent;
  }

  .btn--ghost:hover {
    color: var(--text);
    background: var(--bg-hover);
  }

  /* === Stats === */
  .stats {
    display: flex;
    align-items: center;
    padding: 24px 0;
    gap: 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0 20px;
  }

  .stat:first-child { padding-left: 0; }
  .stat:last-child { padding-right: 0; }

  .stat-num {
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: 500;
    color: var(--accent);
    line-height: 1.1;
  }

  .stat-label {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .stat-sep {
    width: 1px;
    height: 32px;
    background: var(--border-light);
    flex-shrink: 0;
  }

  /* === Section === */
  .section {
    padding: 32px 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .section-link {
    font-size: 12px;
    color: var(--text-tertiary);
    text-decoration: none;
    font-weight: 500;
  }

  .section-link:hover {
    color: var(--accent);
  }

  .section-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .section-header .section-title {
    margin: 0;
  }

  /* === Grid 2x2 === */
  .grid-2x2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .card {
    display: flex;
    gap: 14px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    align-items: flex-start;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-hover);
    transform: translateY(-1px);
  }

  .card--accent {
    border-color: var(--accent);
    background: var(--accent-bg);
  }

  .card--accent:hover {
    background: var(--accent-bg);
    border-color: var(--accent-hover);
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.12);
  }

  .card-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .card--accent .card-icon {
    background: var(--accent);
    color: var(--text-on-accent);
  }

  .card-body {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }

  .card--accent .card-title {
    color: var(--accent);
  }

  .card-desc {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 3px;
    line-height: 1.45;
  }

  /* === Episode list === */
  .episodes-list {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-card);
  }

  .ep-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--border-light);
    transition: background 0.15s;
  }

  .ep-row:last-child {
    border-bottom: none;
  }

  .ep-row:hover {
    background: var(--bg-hover);
  }

  .ep-row:hover .ep-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  .ep-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
    flex-shrink: 0;
    width: 2.8em;
  }

  .ep-title {
    flex: 1;
    font-size: 13px;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ep-arrow {
    flex-shrink: 0;
    color: var(--text-tertiary);
    transition: transform 0.2s, color 0.2s;
  }

  /* === About === */
  .about {
    padding-bottom: 0;
  }

  .about-content {
    max-width: 640px;
  }

  .about-text {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-top: 8px;
  }

  .about-credit {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border-light);
    font-size: 13px;
    color: var(--text-tertiary);
  }

  .about-credit a {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
  }

  .about-credit a:hover {
    color: var(--accent);
  }

  /* === Responsive === */
  @media (max-width: 820px) {
    .hero {
      flex-direction: column;
      gap: 24px;
      padding: 32px 0;
    }

    .hero-visual {
      width: 100%;
      max-width: 300px;
    }

    .hero-title {
      font-size: 28px;
    }

    .grid-2x2 {
      grid-template-columns: 1fr;
    }

    .stats {
      flex-wrap: wrap;
      gap: 12px 0;
    }

    .stat {
      padding: 0 16px;
    }

    .stat:first-child {
      padding-left: 0;
    }

  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 24px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }

    .stats {
      gap: 0;
    }

    .stat {
      flex: 1 0 33%;
      align-items: center;
      padding: 8px 0;
    }

    .stat-sep {
      display: none;
    }

    .section {
      padding: 24px 0;
    }
  }
</style>
