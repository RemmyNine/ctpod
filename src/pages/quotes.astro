---
import DocLayout from "@layouts/DocLayout.astro";
import { getCollection } from "astro:content";
import bookletData from "../data/booklet-data.json";

const episodes = await getCollection("episodes");
const episodeMap = new Map(episodes.map(ep => [ep.data.episode, ep]));

// Get all suggestions with episode info
const allSuggestions = bookletData.suggestions || [];
const quotes = allSuggestions
  .map((s: any) => ({
    text: s.text,
    episode: s.episode,
    title: episodeMap.get(s.episode)?.data.title || `Episode ${s.episode}`,
  }))
  .sort((a: any, b: any) => b.episode - a.episode);
---

<DocLayout title="Good Quotes — CTBBP">
  <div class="quotes-page">
    <header class="quotes-header">
      <div class="quotes-label">Good Quotes</div>
      <h1>Wisdom from the Podcast</h1>
      <p class="quotes-sub">
        Notable quotes, advice, and insights from hackers and researchers across all 179 episodes.
      </p>
      <div class="quotes-count">{quotes.length} quotes from 179 episodes</div>
    </header>

    <div class="quotes-list">
      {quotes.map((q: any) => (
        <a href={`/blog/${q.episode}`} class="quote-item">
          <div class="quote-mark">"</div>
          <div class="quote-content">
            <p class="quote-text">{q.text}</p>
            <div class="quote-meta">
              <span class="quote-ep">#{String(q.episode).padStart(3, "0")}</span>
              <span class="quote-title">{q.title}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</DocLayout>

<style>
  .quotes-page {
    max-width: 720px;
  }

  .quotes-header {
    margin-bottom: 40px;
  }

  .quotes-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .quotes-header h1 {
    font-family: var(--font-body);
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .quotes-sub {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .quotes-count {
    font-size: 13px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .quotes-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .quote-item {
    display: flex;
    gap: 16px;
    padding: 20px 24px;
    background: var(--bg-card);
    text-decoration: none;
    transition: background 0.15s;
  }

  .quote-item:hover {
    background: var(--bg-hover, rgba(0, 0, 0, 0.02));
  }

  .quote-mark {
    font-family: Georgia, serif;
    font-size: 48px;
    line-height: 1;
    color: var(--accent);
    opacity: 0.3;
    flex-shrink: 0;
    width: 32px;
    text-align: center;
  }

  .quote-content {
    flex: 1;
    min-width: 0;
  }

  .quote-text {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text);
    margin: 0 0 10px;
    font-style: italic;
  }

  .quote-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
  }

  .quote-ep {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent);
    flex-shrink: 0;
  }

  .quote-title {
    color: var(--text-tertiary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 640px) {
    .quote-item {
      padding: 16px;
    }

    .quote-mark {
      font-size: 36px;
      width: 24px;
    }

    .quote-text {
      font-size: 14px;
    }
  }
</style>
